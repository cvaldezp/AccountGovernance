# Plantilla de referencia para el ambiente Development — no incluir secretos.
# El App Registration de Entra ID de este ambiente es independiente de QA/Producción
# (ver .env.qa.example / .env.production.example).
#
# El frontend siempre llama al backend por ruta relativa (/api/...), resuelta contra
# el mismo origen vía IIS/HAProxy — no existe (ni hace falta) una variable de URL base
# del backend.

VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_API_SCOPE=api://<client-id>/access_as_user
VITE_USE_MOCK_DATA=false
