# Nota: el frontend llama al backend siempre por ruta relativa (/api/...), resuelta
# contra el mismo origen — vía el proxy de Vite en dev, o vía IIS/HAProxy en despliegues.
# No existe una variable de "URL base del backend"; no hace falta configurar ninguna
# para que las llamadas a la API funcionen en un ambiente nuevo.

# ── Microsoft Entra ID (Azure AD) ────────────────────────────────────────────
# Registro de aplicación del FRONTEND en el portal Azure
VITE_AZURE_CLIENT_ID=

# ID del tenant de la organización
VITE_AZURE_TENANT_ID=

# Scope que expone el backend (api://<backend-client-id>/access_as_user)
# Si usas un único registro de app para frontend y backend, es el mismo clientId.
VITE_AZURE_API_SCOPE=

# Habilita el fallback a datos mock SOLO cuando la API es inalcanzable (network error).
# Nunca se usa si la API respondió (incluidos 401/403/500) — en ese caso siempre se
# muestra el error real. Dejar sin definir (o distinto de "true") en producción.
VITE_USE_MOCK_DATA=false
