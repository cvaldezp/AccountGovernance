<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting config for the ASP.NET Core Module v2 (in-process).
  Checked into source control so `dotnet publish` always includes it verbatim —
  see the "web.config" Content item and SetWebConfigEnvironment target in the .csproj.

  ASPNETCORE_ENVIRONMENT below is the default used when publishing without an override.
  To publish for a different environment without editing this file:
    dotnet publish -c Release -p:EnvironmentName=QA
    dotnet publish -c Release -p:EnvironmentName=Production
  The .csproj's SetWebConfigEnvironment target rewrites this value in the published
  copy only — this source file always stays at its checked-in default.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\AccountGovernance.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Development" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
